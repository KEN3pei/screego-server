# ============================================================
# Screego 設定ファイルのテンプレート
# このファイルを .env にコピーして各値を設定してください
# ============================================================

# ---------------------------------------------------------
# [必須] サーバーの外部 IP アドレス
# 以下のコマンドで確認できます:
#   curl 'https://api.ipify.org'
#
# 固定 IP がない場合は DNS 名で指定可能:
#   SCREEGO_EXTERNAL_IP=dns:your.domain.example.com
# ---------------------------------------------------------
SCREEGO_EXTERNAL_IP=203.0.113.1

# ---------------------------------------------------------
# [必須] Cookie 認証用のシークレットキー (十分に長いランダム文字列)
# 以下のコマンドで生成できます:
#   openssl rand -hex 32
# ---------------------------------------------------------
SCREEGO_SECRET=change-me-to-a-long-random-secret

# ---------------------------------------------------------
# [必須] 公開するドメイン名 (nginx TLS 設定に使用)
# ---------------------------------------------------------
DOMAIN=screego.your-domain.example.com

# ---------------------------------------------------------
# [必須] Let's Encrypt に登録するメールアドレス
# ---------------------------------------------------------
CERTBOT_EMAIL=your-email@example.com

# ---------------------------------------------------------
# 認証モード
#   all  : 常にログイン必須
#   turn : TURN 接続時のみ認証必須 (推奨)
#   none : 認証なし (開発・テスト用のみ)
# ---------------------------------------------------------
SCREEGO_AUTH_MODE=turn

# ログレベル (debug / info / warn / error)
SCREEGO_LOG_LEVEL=info

# オーナーが退室したときにルームを閉じるか
SCREEGO_CLOSE_ROOM_WHEN_OWNER_LEAVES=true

# セッションタイムアウト (秒) / 0 = ブラウザセッションが終わるまで有効
SCREEGO_SESSION_TIMEOUT_SECONDS=0
